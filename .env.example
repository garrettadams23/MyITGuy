# Copy this file to .env for local dev and never commit the real values.
#
# Production values live in GitHub Secrets, not in Netlify's dashboard or a
# committed .env file. Add each variable below as a repo secret (Settings ->
# Secrets and variables -> Actions -> Secrets), then run the "Sync secrets to
# Netlify" workflow from the Actions tab to push them into the right Netlify
# site. See .github/workflows/sync-secrets-to-netlify.yml.

# Neon (existing contact form storage)
NEON_DB_URL=

# Resend (existing contact form email notification)
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=
NOTIFY_TO_EMAIL=

# Supabase (@supabase/server)
# Copy the real values from the Supabase dashboard's Connect dialog.
# SUPABASE_SECRET_KEY bypasses Row-Level Security — keep it server-side only,
# never expose it to the browser, and never commit it.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# Supabase CLI (manages supabase/config.toml + supabase/migrations from this
# repo instead of the dashboard - see .github/workflows/supabase-config-push.yml)
# SUPABASE_ACCESS_TOKEN: personal access token from
#   https://supabase.com/dashboard/account/tokens (required)
# SUPABASE_DB_PASSWORD: the project's Postgres password, from Project Settings
#   -> Database (optional - only needed to push supabase/migrations/*.sql;
#   omit it if you only want to push config.toml settings)
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
